{
  "extends": "@ember/app-tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "test-app/tests/*": ["tests/*"],
      "test-app/*": ["app/*"],
      "*": ["types/*"]
    },
    "target": "esnext",
    "types": ["ember-source/types"]
  },
  "include": ["app/**/*", "tests/**/*", "types/**/*"]
}
