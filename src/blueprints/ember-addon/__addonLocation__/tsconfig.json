{
  "extends": "@ember/library-tsconfig",
  "compilerOptions": {
    "declarationDir": "declarations",<% if (options.packages.addon.hasGlint) { %>
    "plugins": [
      {
        "name": "@glint/tsserver-plugin"
      }
    ],<% } %>
    "rootDir": "./src",
    "target": "esnext",<% if (options.packages.addon.hasGlint) { %>
    "types": ["ember-source/types", "@glint/ember-tsc/types"]<% } else { %>
    "types": ["ember-source/types"]<% } %>
  },
  "include": ["src/**/*", "unpublished-development-types/**/*"]
}
